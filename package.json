{
  "name": "eatfit-bot",
  "version": "1.0.0",
  "description": "Telegram bot for Eat&fit food delivery service (RU/UZ)",
  "main": "src/bot.js",
  "type": "commonjs",
  "private": true,
  "workspaces": [
    "libs/*",
    "apps/*"
  ],
  "scripts": {
    "start": "node src/bot.js",
    "dev": "node src/bot.js",
    "db:init": "node scripts/init-db.js",
    "shared:build": "npm run build -w @eatfit/shared",
    "api:build": "npm run build -w @eatfit/api",
    "api:dev": "npm run start:dev -w @eatfit/api"
  },
  "keywords": [
    "telegram",
    "bot",
    "food-delivery",
    "eatfit"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "node-telegram-bot-api": "^0.66.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.4"
  }
}
