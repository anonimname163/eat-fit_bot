# Telegram bot token from @BotFather
BOT_TOKEN=

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/eatfit

# Admin telegram ids (comma separated). These users get the admin role automatically.
ADMIN_TELEGRAM_IDS=123456789,987654321

# Group chat id where new orders are sent for cooks
COOK_GROUP_ID=-100xxxxxxxxx

# Group chat id where ready orders are sent for couriers
COURIER_GROUP_ID=-100xxxxxxxxx

# Group chat id for admins: all orders land here and update in real time
ADMIN_GROUP_ID=-100xxxxxxxxx

# Daily summary settings (sent to ADMIN_GROUP_ID)
TZ_OFFSET_HOURS=5        # timezone offset from UTC (Uzbekistan = 5)
DAILY_REPORT_HOUR=19     # local hour to send the daily summary (0-23)

# Bot username WITHOUT @ — used to build deep links
BOT_USERNAME=eatfit_bot

# Channel for publishing posts directly (no "forwarded from").
# Bot must be an admin of this channel. Use @channelusername or -100xxxxxxxxx
CHANNEL_ID=@eatfit_channel

# ---- Mini App / website (optional) ----
# Public HTTPS url of the Mini App. When set, the bot shows a menu button
# and an "Open app" button. On Railway use the public domain of this service.
WEB_APP_URL=https://your-app.up.railway.app

# Web server port (Railway sets PORT automatically; locally defaults to 3000)
PORT=3000
