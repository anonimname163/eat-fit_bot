# Telegram bot token from @BotFather
BOT_TOKEN=

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/eatfit

# Admin telegram ids (comma separated). These users get the admin role automatically.
ADMIN_TELEGRAM_IDS=123456789,987654321

# Group chat id where new orders are sent for cooks
COOK_GROUP_ID=-100xxxxxxxxx

# Group chat id where ready orders are sent for couriers
COURIER_GROUP_ID=-100xxxxxxxxx

# Bot username WITHOUT @ — used to build deep links
BOT_USERNAME=eatfit_bot
